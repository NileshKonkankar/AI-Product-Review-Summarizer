PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# MongoDB Atlas connection string. Leave empty to use in-memory demo history.
MONGODB_URI=

# AI_PROVIDER can be gemini, groq, together, huggingface, or local.
AI_PROVIDER=local

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3
